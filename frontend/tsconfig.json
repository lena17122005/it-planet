{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmit": true,
    "types": [
      "vite/client",
      "node"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
